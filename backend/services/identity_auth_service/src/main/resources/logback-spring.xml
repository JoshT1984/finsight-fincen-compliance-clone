<?xml version="1.0" encoding="UTF-8"?>
<configuration>

<!-- ===================== -->
    <!-- Console appender -->
    <!-- ===================== -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level %logger - %msg%n</pattern>
        </encoder>
    </appender>

    <appender name="IDENTITY_SECURITY_FILE" class="ch.qos.logback.core.FileAppender">
        <!-- For production -->
        <!-- <file>/var/log/audit/audit.log</file>  -->
        <!-- For local development -->
        <file>logs/audit/audit.log</file>  
        <encoder>
            <pattern>%msg%n</pattern>
        </encoder>

    <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
        <fileNamePattern>/var/log/audit/audit.%d{yyyy-MM-dd}.log</fileNamePattern>
        <maxHistory>7</maxHistory>
    </rollingPolicy>
    </appender>

    <logger name="IDENTITY_SECURITY" level="INFO" additivity="false">
        <appender-ref ref="IDENTITY_SECURITY_FILE"/>
    </logger>

    <root level="ERROR">
        <appender-ref ref="CONSOLE"/>
    </root>

</configuration>