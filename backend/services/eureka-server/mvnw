#!/bin/sh

##############################################################################
# Maven Wrapper script for UNIX
##############################################################################

# ----------------------------------------------------------------------------
# Ensure Maven is installed
# ----------------------------------------------------------------------------
if [ -z "$MAVEN_HOME" ]; then
  MAVEN_CMD="mvn"
else
  MAVEN_CMD="$MAVEN_HOME/bin/mvn"
fi

# ----------------------------------------------------------------------------
# Pass all arguments to Maven
# ----------------------------------------------------------------------------
exec "$MAVEN_CMD" "$@"
