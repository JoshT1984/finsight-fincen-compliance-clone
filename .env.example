# FinSight Local Development - copy to .env if needed
# docker compose reads .env automatically

RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VIRTUAL_HOST=/

# CORS: allowed origins for frontend (comma-separated). Default: http://localhost:4200
# For AWS: set to your frontend URL(s), e.g. https://app.example.com
# CORS_ALLOWED_ORIGINS=http://localhost:4200
